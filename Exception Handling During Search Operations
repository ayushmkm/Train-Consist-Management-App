import java.util.*;

class Train {
    private List<Integer> bogies = new ArrayList<>();

    public void addBogie(int id) {
        bogies.add(id);
    }

    public int searchBogie(int key) {
        if (bogies.isEmpty()) {
            throw new IllegalStateException("No bogies available in the train to search");
        }

        for (int i = 0; i < bogies.size(); i++) {
            if (bogies.get(i) == key) {
                return i;
            }
        }
        return -1;
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Train train = new Train();

        int n = sc.nextInt();

        for (int i = 0; i < n; i++) {
            train.addBogie(sc.nextInt());
        }

        int key = sc.nextInt();

        try {
            int result = train.searchBogie(key);
            if (result != -1) {
                System.out.println("Bogie found at index: " + result);
            } else {
                System.out.println("Bogie not found");
            }
        } catch (IllegalStateException e) {
            System.out.println(e.getMessage());
        }
    }
}
