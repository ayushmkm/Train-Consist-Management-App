import java.util.Arrays;
import java.util.List;

class GoodsBogie {
    private String type;
    private String cargo;

    public GoodsBogie(String type, String cargo) {
        this.type = type;
        this.cargo = cargo;
    }

    public String getType() {
        return type;
    }

    public String getCargo() {
        return cargo;
    }
}

public class TrainSafetyValidator {
    public static void main(String[] args) {
        List<GoodsBogie> trainBogies = Arrays.asList(
            new GoodsBogie("Boxcar", "Electronics"),
            new GoodsBogie("Cylindrical", "Petroleum"),
            new GoodsBogie("Flatbed", "Steel Pipes"),
            new GoodsBogie("Cylindrical", "Petroleum")
        );

        boolean isTrainSafetyCompliant = trainBogies.stream()
            .allMatch(bogie -> 
                !bogie.getType().equalsIgnoreCase("Cylindrical") || 
                bogie.getCargo().equalsIgnoreCase("Petroleum")
            );

        System.out.println("Safety Compliance Status: " + isTrainSafetyCompliant);
        
        if (isTrainSafetyCompliant) {
            System.out.println("The train is marked safe and ready for departure.");
        } else {
            System.out.println("Safety violation: Cylindrical bogies may only carry Petroleum.");
        }
    }
}
